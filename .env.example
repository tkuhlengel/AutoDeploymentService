# Gitea/Forgejo Webhook Auto-updater Configuration

# Webhook secret for signature verification
# Generate a secure random string and configure the same in your Gitea webhook settings
# Example: openssl rand -hex 32
WEBHOOK_SECRET=your_secure_webhook_secret_here

# Port to listen on for incoming webhooks
PORT=9000

# Absolute path to the git repository to monitor and update
REPO_PATH=${HOME}/ManagedFileTransfer

# Absolute path to the deployment update script
UPDATE_SCRIPT=${HOME}/ManagedFileTransfer/prod_config/scripts/uv_update_deployment.sh

# Directory for log files
LOG_DIR="${HOME}/.local/log/autoupdater"

## INSTALLER VARIABLES
INSTALL_DIR="${HOME}/autodeployer"
SERVICE_FILE="autodeployment.service"
SYSTEMD_DIR="/etc/systemd/system"
LOG_DIR="${HOME}/.local/log/autodeploymentservice"